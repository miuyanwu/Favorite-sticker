<Window x:Class="FavoriteSticker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FavoriteSticker.ViewModels"
        xmlns:models="clr-namespace:FavoriteSticker.Models"
        Title="Favorite Sticker"
        Width="600" Height="500"
        MinWidth="350" MinHeight="300"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="{Binding IsTopmost}"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <vm:MainViewModel x:Key="VM"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Title Bar (custom, since WindowStyle=None) -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Padding="12,8" Cursor="Hand">
                <Grid>
                    <TextBlock Text="Favorite Sticker" FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#x1F4CC;" x:Name="PinButton"
                                Width="28" Height="28" FontSize="12"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="PinButton_Click"
                                ToolTip="Always on Top"/>
                        <Button Content="&#x2699;" Click="SettingsButton_Click"
                                Width="28" Height="28" FontSize="14"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" ToolTip="Settings"/>
                        <Button Content="&#x2715;" Click="CloseButton_Click"
                                Width="28" Height="28" FontSize="14"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" ToolTip="Hide to Tray"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Left Sidebar: Favorites Tree -->
            <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,1,0"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Favorites" FontWeight="SemiBold"
                               Padding="8,6" Grid.Row="0"/>

                    <ListBox x:Name="FolderListBox" Grid.Row="1"
                             ItemsSource="{Binding FolderTree}"
                             SelectedItem="{Binding SelectedFolderId, Mode=TwoWay}"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.Resources>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="" Width="16"/> <!-- depth spacer -->
                                    <TextBlock Text="&#x1F4C1;" Margin="4,0"/>
                                    <TextBlock Text="{Binding Path=Folder.Name}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="4">
                        <Button Content="+ Folder" Click="AddFolder_Click"
                                Padding="6,2" FontSize="11"
                                Background="{StaticResource AccentBrush}"
                                Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Search Bar -->
            <Border Grid.Row="1" Grid.Column="1" Padding="0">
                <Grid>
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchBoxStyle}"
                             FontSize="13">
                        <TextBox.Resources>
                            <VisualBrush x:Key="Watermark">
                                <VisualBrush.Visual>
                                    <TextBlock Text="Search..." Foreground="Gray" FontStyle="Italic"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </TextBox.Resources>
                    </TextBox>
                    <Button Content="&#x2605;" x:Name="StarredFilterBtn"
                            HorizontalAlignment="Right" Margin="0,0,8,0"
                            Width="28" Height="28"
                            Click="StarredFilter_Click"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="Show starred only"/>
                </Grid>
            </Border>

            <!-- Right Content: Item List -->
            <ListBox Grid.Row="2" Grid.Column="1"
                     x:Name="ItemListBox"
                     ItemsSource="{Binding Items}"
                     BorderThickness="0"
                     Background="Transparent"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.ScrollUnit="Pixel"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ClipboardItem}">
                        <Border Style="{StaticResource ClipboardItemStyle}"
                                MouseLeftButtonDown="Item_Click"
                                MouseEnter="Item_MouseEnter"
                                MouseLeave="Item_MouseLeave"
                                Tag="{Binding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Star Button -->
                                <Button Grid.Column="0"
                                        Style="{StaticResource StarButtonStyle}"
                                        Click="StarButton_Click"
                                        Tag="{Binding}">
                                    <TextBlock Text="{Binding IsStarred, Converter={StaticResource BoolToVis}}"
                                               Foreground="{StaticResource StarGold}"/>
                                </Button>

                                <!-- Content Preview -->
                                <StackPanel Grid.Column="1" Margin="4,0" VerticalAlignment="Center">
                                    <!-- Text content -->
                                    <TextBlock Text="{Binding TextContent, TargetNullValue=''}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="40"
                                               FontSize="12"
                                               Foreground="{StaticResource TextBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ContentType}" Value="1">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!-- Image thumbnail -->
                                    <Image Source="{Binding ThumbnailPath}"
                                           MaxWidth="80" MaxHeight="60"
                                           Stretch="Uniform">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ContentType}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <TextBlock Text="{Binding CopyCount, StringFormat='x{0}'}"
                                               FontSize="10" Foreground="Gray">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CopyCount}" Value="1">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Timestamp -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding LastCopiedAt, StringFormat='{}{0:MM-dd HH:mm}'}"
                                           FontSize="10" Foreground="Gray"
                                           VerticalAlignment="Center" Margin="8,0"/>

                                <!-- Delete button -->
                                <Button Grid.Column="3" Content="&#x2715;"
                                        Style="{StaticResource StarButtonStyle}"
                                        Foreground="Gray"
                                        Click="DeleteButton_Click"
                                        Tag="{Binding}"
                                        ToolTip="Delete"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Status bar -->
            <Border Grid.Row="3" Grid.ColumnSpan="2"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Items.Count, StringFormat='{}{0} items'}"
                               FontSize="11" Foreground="Gray"/>
                    <Button Content="Clear Non-Favorites" Click="ClearNonFavorites_Click"
                            Margin="12,0,0,0" FontSize="11"
                            Background="Transparent" BorderThickness="0"
                            Foreground="Gray" Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- Hover Preview Tooltip -->
            <Popup x:Name="HoverPopup"
                   Placement="Mouse"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   StaysOpen="False">
                <Border Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="10" MaxWidth="300" MaxHeight="200">
                    <StackPanel>
                        <TextBlock x:Name="HoverPreviewText"
                                   TextWrapping="Wrap" FontSize="12"
                                   Foreground="{StaticResource TextBrush}"/>
                        <Image x:Name="HoverPreviewImage"
                               MaxWidth="280" MaxHeight="180"
                               Stretch="Uniform"/>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</Window>
