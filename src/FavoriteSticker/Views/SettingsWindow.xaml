<Window x:Class="FavoriteSticker.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="480" Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Hotkey -->
        <GroupBox Header="Hotkey" Grid.Row="0" Margin="0,0,0,8" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Current:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="CurrentHotkeyText" Grid.Column="1"
                           Text="Alt+V" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="Change" Grid.Column="2" x:Name="ChangeHotkeyBtn"
                        Click="ChangeHotkey_Click" Padding="12,4" Cursor="Hand"/>
            </Grid>
        </GroupBox>

        <!-- Cleanup -->
        <GroupBox Header="Auto Cleanup" Grid.Row="1" Margin="0,0,0,8" Padding="8">
            <StackPanel>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Max History:" VerticalAlignment="Center"/>
                    <TextBox x:Name="MaxHistoryBox" Grid.Column="1" Width="80"
                             HorizontalAlignment="Left" VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="items"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Max Age:" VerticalAlignment="Center"/>
                    <TextBox x:Name="MaxAgeBox" Grid.Column="1" Width="80"
                             HorizontalAlignment="Left" VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="days"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Max Text Size:" VerticalAlignment="Center"/>
                    <TextBox x:Name="MaxTextCharsBox" Grid.Column="1" Width="80"
                             HorizontalAlignment="Left" VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="characters"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Max Image Size:" VerticalAlignment="Center"/>
                    <TextBox x:Name="MaxImageSizeBox" Grid.Column="1" Width="80"
                             HorizontalAlignment="Left" VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="MB"/>
                </Grid>
                <CheckBox x:Name="DedupCheckBox" Content="Enable duplicate merging"
                          Margin="0,6,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Auto Start -->
        <GroupBox Header="Startup" Grid.Row="2" Margin="0,0,0,8" Padding="8">
            <CheckBox x:Name="AutoStartCheckBox"
                      Content="Start automatically when Windows starts (no admin required)"/>
        </GroupBox>

        <!-- Storage -->
        <GroupBox Header="Storage" Grid.Row="3" Margin="0,0,0,8" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Data Path:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="DataPathBox" Grid.Column="1"
                         VerticalContentAlignment="Center"/>
                <Button Content="Browse" Grid.Column="2" Click="BrowseDataPath_Click"
                        Margin="8,0,0,0" Padding="12,4" Cursor="Hand"/>
            </Grid>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Click="Save_Click" Padding="16,6"
                    Background="{StaticResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"/>
            <Button Content="Cancel" Click="Cancel_Click" Padding="16,6"
                    BorderThickness="1" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
