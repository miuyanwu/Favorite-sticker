<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors follow Windows system theme -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource {x:Static SystemColors.WindowColorKey}}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{DynamicResource {x:Static SystemColors.WindowTextColorKey}}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource {x:Static SystemColors.ActiveBorderColorKey}}"/>

    <SolidColorBrush x:Key="StarGold" Color="#FFD700"/>
    <SolidColorBrush x:Key="StarredBg" Color="#3A3A00"/>
    <SolidColorBrush x:Key="HoverBg" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}" Opacity="0.1"/>

    <!-- Item template style -->
    <Style x:Key="ClipboardItemStyle" TargetType="Border">
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="0,1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource HoverBg}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Star button style -->
    <Style x:Key="StarButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Search box style -->
    <Style x:Key="SearchBoxStyle" TargetType="TextBox">
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="8,4"/>
    </Style>

</ResourceDictionary>
